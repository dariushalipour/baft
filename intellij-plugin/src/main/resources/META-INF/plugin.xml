<idea-plugin>
    <id>com.baft.intellij</id>
    <name>🧶 Baft</name>
    <vendor>dariushalipour</vendor>

    <description>
        Surfaces 🧶 Baft architecture violations as editor diagnostics (red squiggles and Problems view entries).
        Requires the baft CLI to be installed and available in PATH.
    </description>

    <idea-version since-build="241"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="BAFT" displayType="BALLOON"/>
        <externalAnnotator
            language=""
            implementationClass="com.baft.intellij.BaftAnnotator"/>
        <formattingService implementation="com.baft.intellij.BaftFormattingService"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.baft.intellij.BaftConfigurable"
            id="com.baft.intellij.BaftConfigurable"
            displayName="🧶 Baft"/>
    </extensions>
</idea-plugin>
