{
  "name": "baft",
  "displayName": "🧶 Baft",
  "description": "Architecture violation diagnostics powered by the 🧶 Baft CLI",
  "version": "0.1.2",
  "publisher": "dariushalipour",
  "repository": {
    "type": "git",
    "url": "https://github.com/dariushalipour/baft"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Formatters"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "BAFT",
      "properties": {
        "baft.format.colorPalette": {
          "type": "string",
          "enum": ["vibrant", "muted", "mono", "none"],
          "default": "vibrant",
          "scope": "resource",
          "markdownDescription": "Specifies the Mermaid color palette BAFT uses when formatting BAFT.md files."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
